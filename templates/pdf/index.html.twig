{% extends 'base.html.twig' %}

{% block title %}Conversion URL vers PDF{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="container">
        <div class="card">
            <div class="card-header">
                <h1 class="mb-0">
                    <i class="bi bi-file-pdf"></i> Convertisseur URL vers PDF
                </h1>
                <p class="mb-0 mt-2">Générez un PDF à partir de n'importe quelle URL en utilisant Gotenberg</p>
            </div>
            <div class="card-body p-4">
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>Erreur !</strong> {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {{ form_start(form) }}
                <div class="mb-4">
                    {{ form_label(form.url) }}
                    {{ form_widget(form.url) }}
                    {{ form_errors(form.url) }}
                    <div class="form-text">Entrez l'URL complète de la page que vous souhaitez convertir en PDF</div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_end(form) }}
            </div>
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
